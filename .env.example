# Terraria Server - Environment variables template
# Copy this file to .env and edit the values as needed.

# Env file used by docker-compose. Default .env
ENV_FILE=.env

# Only change this value if you know what you are doing.
# Terraria version without dots (e.g. 1.4.5.3 = 1453)
TERRARIA_VERSION=1453

# Message broadcast to players when the server shuts down
TERRARIA_SHUTDOWN_MESSAGE=Server is shutting down NOW!

# Autosave interval in minutes
TERRARIA_AUTOSAVE_INTERVAL=10

# Server settings
TERRARIA_MOTD=Welcome to my Terraria Server!
TERRARIA_PASS=docker
TERRARIA_MAXPLAYERS=8
TERRARIA_WORLDNAME=Docker
TERRARIA_WORLDSIZE=3
TERRARIA_WORLDSEED=Docker

# Use config file instead of env vars: Yes/No
TERRARIA_USECONFIGFILE=No

# Host port to publish (container always listens on 7777). Default 7777
TERRARIA_PORT=7777

# Host path for world data (direct bind mount). Default ./terraria-data (relative to project)
TERRARIA_DATA_PATH=./terraria-data
